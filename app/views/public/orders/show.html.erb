<div class="mb-6">
  <h1 class="font-bold text-xl text-gray-900"><%= @event.title %></h1>
  <p class="text-sm text-gray-500 mt-1">
    <%= @event.event_date.strftime("%Y年%-m月%-d日") %>
    <% if @event.venue.present? %>
      ・<%= @event.venue %>
    <% end %>
  </p>
</div>

<div class="bg-white rounded-lg border border-gray-200 p-6">
  <div class="text-center mb-6">
    <p class="text-green-600 font-semibold text-lg">注文が完了しました</p>
    <p class="text-sm text-gray-500 mt-1">ありがとうございます！</p>
  </div>

  <div class="border-t border-gray-100 pt-4 space-y-3">
    <div>
      <p class="text-xs text-gray-400">お名前</p>
      <p class="text-gray-900"><%= @order.customer_name %></p>
    </div>

    <div>
      <p class="text-xs text-gray-400 mb-1">注文内容</p>
      <% @order.order_items.includes(:ticket_type).each do |item| %>
        <div class="flex justify-between text-sm py-1">
          <span class="text-gray-700"><%= item.ticket_type.name %> × <%= item.quantity %>枚</span>
          <span class="text-gray-900"><%= number_to_currency(item.quantity * item.ticket_type.price, unit: "¥", strip_insignificant_zeros: true) %></span>
        </div>
      <% end %>
      <div class="flex justify-between font-medium border-t border-gray-100 pt-2 mt-2">
        <span>合計</span>
        <span><%= number_to_currency(@order.total_amount, unit: "¥", strip_insignificant_zeros: true) %></span>
      </div>
    </div>

    <% if @order.note.present? %>
      <div>
        <p class="text-xs text-gray-400">備考</p>
        <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= @order.note %></p>
      </div>
    <% end %>
  </div>

  <p class="text-xs text-gray-400 mt-6 text-center">お支払い・チケット受け渡しの詳細はジムにてご確認ください。</p>
</div>
