<div class="text-center mb-6 mt-4">
  <div class="inline-flex items-center justify-center w-12 h-12 bg-green-100 text-green-500 rounded-full mb-6">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-10 h-10">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
    </svg>
  </div>
  <h1 class="text-2xl font-bold text-gray-800 mb-6">注文が完了しました</h1>

  <section class="w-full bg-blue-50 border border-blue-200 rounded-2xl p-6 mb-2 text-left">
    <div class="flex items-start gap-3">
      <div class="mt-1 flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-blue-500">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="space-y-4 w-full">
        <p class="text-sm font-bold text-blue-800 leading-relaxed">
          ご注文内容の控えとして<br>この画面のスクリーンショットを保存してください
        </p>
        <hr class="border-blue-200">
        <p class="text-sm font-bold text-blue-700 leading-relaxed">
          チケットの受け渡しとお支払いは<br>ジムにてマネージャーに直接ご確認ください
        </p>
      </div>
    </div>
  </section>
</div>

<div class="bg-white rounded-2xl border border-gray-100 p-6 mb-6" style="box-shadow: 0 4px 20px rgba(0,0,0,0.05)">
  <div class="border-b border-gray-100 pb-3 mb-4">
    <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">注文内容</span>
  </div>

  <div class="space-y-4 mb-6">
    <div>
      <p class="text-xs text-gray-400 mb-1">イベント名</p>
      <p class="text-lg font-bold text-gray-800"><%= @event.title %></p>
    </div>

    <div>
      <p class="text-xs text-gray-400 mb-1">お名前</p>
      <p class="text-base font-bold text-gray-800"><%= @order.customer_name %> <span class="text-sm font-normal text-gray-500 ml-1">様</span></p>
    </div>
  </div>

  <div class="bg-gray-50 rounded-xl p-4 space-y-4 mb-6">
    <% @order.order_items.includes(:ticket_type).each do |item| %>
      <div class="flex justify-between items-end border-b border-gray-200 pb-3 last:border-0 last:pb-0">
        <div>
          <p class="font-bold text-gray-800"><%= item.ticket_type.name %></p>
          <p class="text-xs text-gray-400"><%= number_to_currency(item.ticket_type.price, unit: "¥", strip_insignificant_zeros: true) %></p>
        </div>
        <div class="text-right">
          <p class="text-xs text-gray-400 mb-1">× <%= item.quantity %></p>
          <p class="font-bold text-gray-800"><%= number_to_currency(item.quantity * item.ticket_type.price, unit: "¥", strip_insignificant_zeros: true) %></p>
        </div>
      </div>
    <% end %>

    <div class="flex justify-between items-center pt-2">
      <span class="text-gray-500 font-medium">合計金額</span>
      <span class="text-xl font-black text-blue-600"><%= number_to_currency(@order.total_amount, unit: "¥", strip_insignificant_zeros: true) %></span>
    </div>
  </div>

  <% if @order.note.present? %>
    <div>
      <p class="text-xs text-gray-400 mb-2">備考</p>
      <p class="text-sm text-gray-700 whitespace-pre-wrap bg-gray-50 rounded-lg p-3 min-h-[60px]"><%= @order.note %></p>
    </div>
  <% end %>
</div>
