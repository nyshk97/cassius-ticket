<div class="mb-5 text-center">
  <div class="inline-flex items-center justify-center w-12 h-12 bg-blue-100 text-blue-600 rounded-full mb-3">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 010 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 010-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375z" />
    </svg>
  </div>
  <h1 class="font-bold text-xl text-gray-900 tracking-tight leading-snug"><%= @event.title %></h1>
  <div class="flex items-center justify-center gap-2 text-sm text-gray-500 mt-2">
    <span class="flex items-center">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5 mr-1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
      </svg>
      <%= @event.event_date.strftime("%Y年%-m月%-d日") %>
    </span>
    <% if @event.venue.present? %>
      <span class="text-gray-300">|</span>
      <span class="truncate max-w-[120px]"><%= @event.venue %></span>
    <% end %>
  </div>
</div>

<% if @event.description.present? %>
  <div class="bg-gray-100 rounded-lg p-3.5 mb-6 text-sm text-gray-700 whitespace-pre-wrap"><%= @event.description %></div>
<% end %>

<div class="bg-white rounded-2xl border border-gray-200 p-5 shadow-sm">
  <h2 class="font-bold text-lg text-gray-900 mb-4 pb-2 border-b border-gray-100">チケット注文</h2>

  <%= form_with model: [@event, @order], url: event_orders_path(@event.token), class: "space-y-6" do |f| %>
    <% if @order.errors.any? %>
      <div class="bg-red-50 text-red-600 rounded-lg p-4 text-sm border border-red-100">
        <ul class="list-disc list-inside space-y-1">
          <% @order.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :customer_name, "お名前", class: "block text-sm font-bold text-gray-700 mb-1.5" %>
      <%= f.text_field :customer_name, required: true, class: "block w-full rounded-xl border border-gray-300 px-4 py-3 text-base focus:border-blue-500 focus:ring focus:ring-blue-200 transition-shadow bg-gray-50 focus:bg-white", placeholder: "例: 山田太郎" %>
      <p class="text-xs text-gray-400 mt-1.5 ml-1">※LINEの登録名など、誰か分かる名前をお願いします</p>
    </div>

    <fieldset>
      <legend class="text-sm font-bold text-gray-700 mb-2">チケット枚数</legend>
      <div class="space-y-3">
        <%= f.fields_for :order_items do |oif| %>
          <% tt = oif.object.ticket_type %>
          <div class="flex items-center justify-between border border-gray-200 rounded-xl px-4 py-3 bg-gray-50 focus-within:bg-white focus-within:border-blue-300 transition-colors">
            <div>
              <p class="font-bold text-gray-900 text-base"><%= tt.name %></p>
              <p class="text-sm text-gray-500 font-medium"><%= number_to_currency(tt.price, unit: "¥", strip_insignificant_zeros: true) %></p>
            </div>
            <div class="flex items-center gap-2">
              <%= oif.hidden_field :ticket_type_id %>
              <%= oif.number_field :quantity, min: 0, value: oif.object.quantity || 0, class: "w-20 text-center rounded-lg border border-gray-300 px-2 py-2 text-lg font-semibold focus:border-blue-500 focus:ring focus:ring-blue-200 bg-white" %>
              <span class="text-sm font-medium text-gray-500">枚</span>
            </div>
          </div>
        <% end %>
      </div>
    </fieldset>

    <div>
      <%= f.label :note, "備考（任意）", class: "block text-sm font-bold text-gray-700 mb-1.5" %>
      <%= f.text_area :note, rows: 2, class: "block w-full rounded-xl border border-gray-300 px-4 py-3 text-base focus:border-blue-500 focus:ring focus:ring-blue-200 transition-shadow bg-gray-50 focus:bg-white", placeholder: "連絡事項があればご記入ください" %>
    </div>

    <div class="pt-2">
      <%= f.submit "注文を確定する", class: "w-full rounded-xl px-4 py-3.5 bg-blue-600 hover:bg-blue-700 text-white font-bold text-lg shadow-md cursor-pointer transition-transform active:scale-95" %>
    </div>
  <% end %>
</div>
