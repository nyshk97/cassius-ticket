<% content_for :title, "Ticket Order - #{@event.title}" %>

<header class="text-center mb-8" data-purpose="event-header">
  <h1 class="text-3xl font-bold font-gothic mb-2 text-gray-900 tracking-tight">
    <%= @event.title %>
  </h1>
  <div class="flex items-center justify-center gap-4 text-gray-500 text-sm">
    <span class="flex items-center">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <%= @event.event_date.strftime("%Y年%-m月%-d日") %>
    </span>
    <% if @event.venue.present? %>
      <span class="flex items-center">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <%= @event.venue %>
      </span>
    <% end %>
  </div>
</header>

<section class="bg-white rounded-2xl p-8 card-shadow" data-purpose="order-form-container">
  <%= form_with model: [@event, @order], url: public_event_orders_path(@event.token), class: "space-y-8" do |f| %>
    <% if @order.errors.any? %>
      <div class="bg-red-50 text-red-600 rounded-lg p-4 text-sm border border-red-100">
        <ul class="list-disc list-inside space-y-1">
          <% @order.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div data-purpose="form-section-name">
      <%= f.label :customer_name, "お名前", class: "block text-lg font-bold mb-3" %>
      <%= f.text_field :customer_name, required: true, class: "w-full px-4 py-3 rounded-xl border border-gray-200 custom-focus text-gray-700 placeholder-gray-400", placeholder: "例：山田太郎" %>
      <p class="mt-2 text-xs text-gray-400">※LINEの登録名など、誰か分かる名前をお願いします</p>
    </div>

    <div data-purpose="form-section-tickets">
      <label class="block text-lg font-bold mb-4">チケット枚数</label>
      <div class="space-y-3">
        <%= f.fields_for :order_items do |oif| %>
          <% tt = oif.object.ticket_type %>
          <div class="ticket-row bg-white p-4 rounded-2xl flex items-center justify-between shadow-sm" data-controller="ticket-counter">
            <div>
              <p class="font-bold text-gray-900"><%= tt.name %></p>
              <p class="text-gray-500 text-sm"><%= number_to_currency(tt.price, unit: "¥", strip_insignificant_zeros: true) %></p>
            </div>
            <div class="flex items-center gap-4">
              <%= oif.hidden_field :ticket_type_id %>
              <%= oif.number_field :quantity, min: 0, value: oif.object.quantity || 0, class: "sr-only", data: { ticket_counter_target: "input" } %>
              <button type="button" class="w-10 h-10 flex items-center justify-center rounded-full border border-gray-200 text-gray-400 hover:bg-gray-50 transition-colors" data-action="click->ticket-counter#decrement">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                </svg>
              </button>
              <span class="text-lg font-medium w-4 text-center" data-ticket-counter-target="display"><%= oif.object.quantity || 0 %></span>
              <button type="button" class="w-10 h-10 flex items-center justify-center rounded-full border border-gray-200 text-gray-400 hover:bg-gray-50 transition-colors" data-action="click->ticket-counter#increment">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
              </button>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div data-purpose="form-section-remarks">
      <%= f.label :note, "備考（任意）", class: "block text-lg font-bold mb-3" %>
      <%= f.text_area :note, rows: 3, class: "w-full px-4 py-3 rounded-xl border border-gray-200 custom-focus text-gray-700 placeholder-gray-400 resize-none", placeholder: "連絡事項があればご記入ください" %>
    </div>

    <div data-purpose="form-submit">
      <%= f.submit "注文を確定する", class: "w-full bg-brand-blue hover:bg-blue-900 text-white font-bold py-4 px-6 rounded-xl transition-all duration-200 shadow-lg active:transform active:scale-[0.98] cursor-pointer" %>
    </div>
  <% end %>
</section>
