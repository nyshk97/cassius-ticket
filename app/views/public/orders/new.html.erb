<div class="mb-6">
  <h1 class="font-bold text-xl text-gray-900"><%= @event.title %></h1>
  <p class="text-sm text-gray-500 mt-1">
    <%= @event.event_date.strftime("%Y年%-m月%-d日") %>
    <% if @event.venue.present? %>
      ・<%= @event.venue %>
    <% end %>
  </p>
  <% if @event.description.present? %>
    <p class="text-sm text-gray-600 mt-2 whitespace-pre-wrap"><%= @event.description %></p>
  <% end %>
</div>

<div class="bg-white rounded-lg border border-gray-200 p-6">
  <h2 class="font-semibold text-lg mb-4">チケット注文</h2>

  <%= form_with model: [@event, @order], url: event_orders_path(@event.token), class: "space-y-5" do |f| %>
    <% if @order.errors.any? %>
      <div class="bg-red-50 text-red-600 rounded-lg p-4 text-sm">
        <ul class="list-disc list-inside">
          <% @order.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :customer_name, "お名前", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :customer_name, required: true, class: "block w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-blue-600", placeholder: "例: 山田太郎" %>
    </div>

    <fieldset>
      <legend class="text-sm font-medium text-gray-700 mb-3">チケット枚数</legend>
      <div class="space-y-3">
        <%= f.fields_for :order_items do |oif| %>
          <% tt = oif.object.ticket_type %>
          <div class="flex items-center justify-between border border-gray-200 rounded-lg px-4 py-3">
            <div>
              <p class="font-medium text-gray-900"><%= tt.name %></p>
              <p class="text-sm text-gray-500"><%= number_to_currency(tt.price, unit: "¥", strip_insignificant_zeros: true) %></p>
            </div>
            <div class="flex items-center gap-2">
              <%= oif.hidden_field :ticket_type_id %>
              <%= oif.number_field :quantity, min: 0, value: oif.object.quantity || 0, class: "w-20 text-center rounded-md border border-gray-300 px-2 py-1.5 focus:outline-blue-600" %>
              <span class="text-sm text-gray-500">枚</span>
            </div>
          </div>
        <% end %>
      </div>
    </fieldset>

    <div>
      <%= f.label :note, "備考", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :note, rows: 2, class: "block w-full rounded-md border border-gray-300 px-3 py-2 focus:outline-blue-600", placeholder: "連絡事項があれば（任意）" %>
    </div>

    <div>
      <%= f.submit "注文する", class: "w-full rounded-md px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
    </div>
  <% end %>
</div>
