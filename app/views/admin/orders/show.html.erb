<div class="flex items-center justify-between mb-6">
  <h1 class="font-bold text-2xl">注文詳細</h1>
  <div class="flex items-center gap-3">
    <%= button_to "削除", event_order_path(@event, @order), method: :delete,
        data: { turbo_confirm: "この注文を削除しますか？" },
        class: "text-sm px-3 py-1.5 rounded-md border border-red-200 text-red-500 hover:bg-red-50 cursor-pointer" %>
  </div>
</div>

<div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
    <div>
      <p class="text-xs text-gray-400 mb-1">お名前</p>
      <p class="text-gray-900 font-medium text-lg"><%= @order.customer_name %></p>
    </div>
    <div>
      <p class="text-xs text-gray-400 mb-1">注文日時</p>
      <p class="text-gray-900"><%= @order.created_at.strftime("%Y年%-m月%-d日 %H:%M") %></p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <p class="text-xs text-gray-400 mb-1">支払い状況</p>
      <div class="flex items-center gap-2">
        <span class="text-xs px-2 py-1 rounded-full font-medium
          <%= @order.payment_status_paid? ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
          <%= @order.payment_status_i18n %>
        </span>
        <%= button_to @order.payment_status_paid? ? "未払いに戻す" : "支払済にする",
            toggle_payment_event_order_path(@event, @order), method: :patch,
            class: "text-xs text-blue-600 hover:text-blue-500 cursor-pointer" %>
      </div>
    </div>
    <div>
      <p class="text-xs text-gray-400 mb-1">受渡状況</p>
      <div class="flex items-center gap-2">
        <span class="text-xs px-2 py-1 rounded-full font-medium
          <%= @order.delivery_status_delivered? ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-500' %>">
          <%= @order.delivery_status_i18n %>
        </span>
        <%= button_to @order.delivery_status_delivered? ? "未受渡に戻す" : "受渡済にする",
            toggle_delivery_event_order_path(@event, @order), method: :patch,
            class: "text-xs text-blue-600 hover:text-blue-500 cursor-pointer" %>
      </div>
    </div>
  </div>

  <% if @order.note.present? %>
    <div class="mt-4 pt-4 border-t border-gray-100">
      <p class="text-xs text-gray-400 mb-1">備考</p>
      <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= @order.note %></p>
    </div>
  <% end %>
</div>

<div class="bg-white rounded-lg border border-gray-200 p-6 mb-6">
  <h2 class="font-semibold text-lg mb-4">注文内容</h2>
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-gray-200 text-left text-gray-500">
        <th class="pb-2 font-medium">チケット種別</th>
        <th class="pb-2 font-medium text-right">単価</th>
        <th class="pb-2 font-medium text-right">枚数</th>
        <th class="pb-2 font-medium text-right">小計</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @order.order_items.includes(:ticket_type).each do |item| %>
        <tr>
          <td class="py-2 text-gray-900"><%= item.ticket_type.name %></td>
          <td class="py-2 text-gray-600 text-right"><%= number_to_currency(item.ticket_type.price, unit: "¥", strip_insignificant_zeros: true) %></td>
          <td class="py-2 text-gray-900 text-right"><%= item.quantity %>枚</td>
          <td class="py-2 text-gray-900 text-right"><%= number_to_currency(item.quantity * item.ticket_type.price, unit: "¥", strip_insignificant_zeros: true) %></td>
        </tr>
      <% end %>
    </tbody>
    <tfoot>
      <tr class="border-t border-gray-200">
        <td colspan="3" class="py-2 font-medium text-right">合計</td>
        <td class="py-2 font-semibold text-right text-lg"><%= number_to_currency(@order.total_amount, unit: "¥", strip_insignificant_zeros: true) %></td>
      </tr>
    </tfoot>
  </table>
</div>

<div class="mt-4">
  <%= link_to "← #{@event.title}に戻る", event_path(@event), class: "text-sm text-gray-500 hover:text-gray-700" %>
</div>
