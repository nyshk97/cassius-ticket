<div class="mx-auto w-full max-w-sm mt-12 sm:mt-24 px-4">
  <div class="text-center mb-8">
    <div class="inline-flex items-center justify-center w-12 h-12 bg-gray-900 text-white rounded-xl mb-4 shadow-sm">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
        <path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd" />
      </svg>
    </div>
    <h1 class="font-bold text-2xl tracking-tight text-gray-900">Cassius Ticket</h1>
    <p class="text-sm text-gray-500 mt-2">管理者ログイン</p>
  </div>

  <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm">
    <% if alert = flash[:alert] %>
      <div class="p-3 bg-red-50 text-red-600 font-medium rounded-lg text-sm mb-5 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 flex-shrink-0">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-5a.75.75 0 01.75.75v4.5a.75.75 0 01-1.5 0v-4.5A.75.75 0 0110 5zm0 10a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
        </svg>
        <%= alert %>
      </div>
    <% end %>

    <%= form_with url: session_url, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :password, "パスワード", class: "sr-only" %>
        <%= form.password_field :password, required: true, autofocus: true, autocomplete: "current-password", placeholder: "パスワードを入力", maxlength: 72, class: "block w-full rounded-xl border border-gray-300 px-4 py-3 text-base focus:border-gray-900 focus:ring focus:ring-gray-200 transition-shadow bg-gray-50 focus:bg-white" %>
      </div>

      <div class="pt-2">
        <%= form.submit "ログイン", class: "w-full rounded-xl px-4 py-3.5 bg-gray-900 hover:bg-gray-800 text-white font-bold shadow-md cursor-pointer transition-transform active:scale-95" %>
      </div>
    <% end %>
  </div>
</div>
