<div class="flex items-center justify-between mb-6">
  <h1 class="font-bold text-2xl">イベント一覧</h1>
  <%= link_to "新規作成", new_event_path, class: "rounded-md px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium" %>
</div>

<% if @events.any? %>
  <div class="bg-white rounded-lg border border-gray-200 divide-y divide-gray-200">
    <% @events.each do |event| %>
      <%= link_to event, class: "block px-5 py-4 hover:bg-gray-50 transition" do %>
        <div class="flex items-center justify-between">
          <div>
            <p class="font-semibold text-gray-900"><%= event.title %></p>
            <p class="text-sm text-gray-500 mt-1">
              <%= event.event_date.strftime("%Y年%-m月%-d日") %>
              <% if event.venue.present? %>
                ・<%= event.venue %>
              <% end %>
            </p>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xs px-2 py-1 rounded-full font-medium
              <%= event.open? ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
              <%= event.status_i18n %>
            </span>
            <span class="text-sm text-gray-400">
              <%= event.orders.count %>件
            </span>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-16 text-gray-400">
    <p class="text-lg mb-2">まだイベントがありません</p>
    <p class="text-sm">「新規作成」からイベントを追加してください</p>
  </div>
<% end %>
