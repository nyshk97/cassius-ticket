<div class="nested-fields bg-gray-50 rounded-lg border border-gray-200 p-3 relative" data-nested-form-target="field">
  <%= f.hidden_field :id %>

  <div class="grid grid-cols-2 gap-3 mb-3">
    <div class="col-span-2">
      <%= f.label :name, "種別名", class: "block text-xs font-semibold text-gray-600 mb-1" %>
      <%= f.text_field :name, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring focus:ring-blue-200", placeholder: "例：S席" %>
    </div>
    <div>
      <%= f.label :price, "価格（円）", class: "block text-xs font-semibold text-gray-600 mb-1" %>
      <%= f.number_field :price, min: 0, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring focus:ring-blue-200", placeholder: "5000" %>
    </div>
    <div>
      <%= f.label :position, "並び順", class: "block text-xs font-semibold text-gray-600 mb-1" %>
      <%= f.number_field :position, value: f.object.position || 0, class: "block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring focus:ring-blue-200" %>
    </div>
  </div>

  <div class="flex justify-end border-t border-gray-200 pt-2">
    <% if f.object.persisted? %>
      <%= f.check_box :_destroy, { class: "hidden peer", data: { action: "nested-form#markForDestroy" } }, "1", "0" %>
      <button type="button" data-action="nested-form#remove" class="text-red-500 hover:text-red-700 text-xs font-semibold flex items-center gap-1 cursor-pointer px-2 py-1 rounded hover:bg-red-50">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
        </svg>
        削除
      </button>
    <% else %>
      <button type="button" data-action="nested-form#remove" class="text-red-500 hover:text-red-700 text-xs font-semibold flex items-center gap-1 cursor-pointer px-2 py-1 rounded hover:bg-red-50">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
        </svg>
        削除
      </button>
    <% end %>
  </div>
</div>
