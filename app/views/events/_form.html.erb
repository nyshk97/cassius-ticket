<%= form_with model: event, class: "space-y-5" do |f| %>
  <% if event.errors.any? %>
    <div class="bg-red-50 text-red-600 rounded-lg p-4 text-sm shadow-sm border border-red-100">
      <p class="font-semibold mb-2"><%= event.errors.count %>件のエラーがあります:</p>
      <ul class="list-disc list-inside space-y-1">
        <% event.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm space-y-4">
    <div>
      <%= f.label :title, "興行名", class: "block text-sm font-bold text-gray-700 mb-1.5" %>
      <%= f.text_field :title, required: true, class: "block w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-base focus:border-blue-500 focus:ring focus:ring-blue-200 transition-shadow", placeholder: "例：PHOENIX BATTLE 150" %>
    </div>

    <div>
      <%= f.label :player_name, "選手名", class: "block text-sm font-bold text-gray-700 mb-1.5" %>
      <%= f.text_field :player_name, required: true, class: "block w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-base focus:border-blue-500 focus:ring focus:ring-blue-200 transition-shadow", placeholder: "例：栗原宗太郎" %>
    </div>

    <div>
      <%= f.label :event_date, "開催日", class: "block text-sm font-bold text-gray-700 mb-1.5" %>
      <%= f.date_field :event_date, required: true, class: "block w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-base focus:border-blue-500 focus:ring focus:ring-blue-200 transition-shadow" %>
    </div>

    <div>
      <%= f.label :venue, "会場", class: "block text-sm font-bold text-gray-700 mb-1.5" %>
      <%= f.text_field :venue, class: "block w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-base focus:border-blue-500 focus:ring focus:ring-blue-200 transition-shadow", placeholder: "例: 後楽園ホール" %>
    </div>

    <div>
      <%= f.label :description, "説明・備考", class: "block text-sm font-bold text-gray-700 mb-1.5" %>
      <%= f.text_area :description, rows: 3, class: "block w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-base focus:border-blue-500 focus:ring focus:ring-blue-200 transition-shadow", placeholder: "任意" %>
    </div>

    <div>
      <%= f.label :status, "受付状況", class: "block text-sm font-bold text-gray-700 mb-1.5" %>
      <%= f.select :status, Event::STATUS_LABELS.map { |value, label| [label, value] }, {}, class: "block w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-base focus:border-blue-500 focus:ring focus:ring-blue-200 transition-shadow bg-white" %>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-5 shadow-sm" data-controller="nested-form">
    <h3 class="text-sm font-bold text-gray-700 mb-3 flex justify-between items-center">
      <span>チケット種別</span>
    </h3>

    <div data-nested-form-target="container" class="space-y-4 mb-4">
      <%= f.fields_for :ticket_types do |tf| %>
        <%= render "ticket_type_fields", f: tf %>
      <% end %>
    </div>

    <template data-nested-form-target="template">
      <%= f.fields_for :ticket_types, TicketType.new, child_index: "NEW_RECORD" do |tf| %>
        <%= render "ticket_type_fields", f: tf %>
      <% end %>
    </template>

    <button type="button" data-action="nested-form#add" class="w-full flex items-center justify-center gap-2 rounded-lg border-2 border-dashed border-gray-300 px-4 py-3 text-sm font-semibold text-gray-600 hover:text-blue-600 hover:border-blue-400 hover:bg-blue-50 transition-colors cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      チケット種別を追加
    </button>
  </div>

  <div class="pt-4 sticky bottom-4">
    <%= f.submit event.persisted? ? "更新する" : "作成する", class: "w-full rounded-xl px-5 py-3.5 bg-gray-900 hover:bg-gray-800 text-white font-bold text-lg shadow-lg cursor-pointer transition-transform active:scale-95" %>
    <div class="text-center mt-4">
      <%= link_to "キャンセル", event.persisted? ? event_path(event) : events_path, class: "text-sm font-medium text-gray-500 hover:text-gray-900 px-4 py-2" %>
    </div>
  </div>
<% end %>
