<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Cassius Ticket" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Cassius Ticket">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="チケット管理システム">
    <meta property="og:title" content="Cassius Ticket">
    <meta property="og:description" content="チケット管理システム">
    <meta property="og:type" content="website">
    <meta property="og:image" content="<%= image_url("logo.jpeg") %>">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Cassius Ticket">
    <meta name="twitter:description" content="チケット管理システム">
    <meta name="twitter:image" content="<%= image_url("logo.jpeg") %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gray-50 text-gray-800 antialiased font-sans">
    <% if authenticated? %>
      <nav class="bg-white border-b border-gray-200 sticky top-0 z-10 shadow-sm">
        <div class="max-w-md mx-auto px-4 py-3 flex items-center justify-between">
          <div class="flex items-center gap-6">
            <%= link_to "Cassius Ticket", root_path, class: "font-bold text-lg tracking-tight text-gray-900" %>
          </div>
          <%= button_to "ログアウト", session_path, method: :delete, class: "text-xs font-medium text-gray-500 hover:text-gray-900 px-2 py-1 cursor-pointer" %>
        </div>
      </nav>
    <% end %>

    <main class="max-w-md mx-auto px-4 py-6 pb-20">
      <% if flash[:notice] %>
        <p class="mb-5 py-3 px-4 bg-gray-900 text-white rounded-lg text-sm font-medium shadow-md animate-fade-in-down" id="notice"><%= flash[:notice] %></p>
      <% end %>
      <% if flash[:alert] %>
        <p class="mb-5 py-3 px-4 bg-red-50 border border-red-100 text-red-600 rounded-lg text-sm font-medium shadow-sm animate-fade-in-down" id="alert"><%= flash[:alert] %></p>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
